# ── AI ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...   # Optional Claude key from console.anthropic.com
GROQ_API_KEY=gsk_...           # Preferred LLM key from console.groq.com

# ── Stellar Wallets (generate with: node scripts/setup-wallets.js) ─────────
MANAGER_SECRET_KEY=S...        # Manager agent Stellar secret key
MANAGER_PUBLIC_KEY=G...        # Manager agent Stellar public key (optional; derived from secret if omitted)

MANAGER_PUBLIC=G...            # Compatibility alias emitted by scripts/setup-wallets.js
MANAGER_SECRET=S...            # Compatibility alias emitted by scripts/setup-wallets.js

AGENT_PRICE_PUBLIC_KEY=G...    # PriceFeed agent receives payments here
AGENT_PRICE_SECRET=S...        # PriceFeed agent secret (for future signing)
AGENT_NEWS_PUBLIC_KEY=G...     # NewsDigest agent payment recipient
AGENT_NEWS_SECRET=S...         # NewsDigest agent secret
AGENT_SUMMARIZER_PUBLIC_KEY=G... # Summarizer agent payment recipient
AGENT_SUMMARIZE_PUBLIC_KEY=G...  # Alias supported by config.ts (SUMMARIZE vs SUMMARIZER)
AGENT_SUMMARIZER_SECRET=S...     # Summarizer agent secret
AGENT_SUMMARIZE_SECRET=S...      # Alias emitted by setup script
AGENT_SENTIMENT_PUBLIC_KEY=G...  # SentimentAI agent payment recipient
AGENT_SENTIMENT_SECRET=S...      # SentimentAI agent secret
AGENT_MATH_PUBLIC_KEY=G...       # MathSolver agent payment recipient
AGENT_MATH_SECRET=S...           # MathSolver agent secret
AGENT_RESEARCH_PUBLIC_KEY=G...   # DeepResearch agent payment recipient
AGENT_RESEARCH_SECRET=S...       # DeepResearch agent secret

# ── Stellar Network ─────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet        # testnet or mainnet
FACILITATOR_URL=https://x402-stellar-491bf9f7e30b.herokuapp.com  # Official x402 facilitator
X402_USDC_ASSET_ADDRESS=       # Optional USDC asset address override for settlement metadata

# ── Soroban Contract ────────────────────────────────────────────────────────
# REQUIRED: deploy the agent-registry contract and paste the contract id (56-char C… strkey).
CONTRACT_ID=
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org  # Optional; default is testnet RPC

# Development: in-memory demo agents when Soroban sync fails (default on). Set to 0 to disable.
# SYNS_DEMO_CATALOG=0

# Development: skip x402 paywall on /agents/* (default on). Set to 0 to enforce real 402 locally.
# SYNS_DEMO_NO_X402=0

# ── External data (optional; system uses real APIs when set) ────────────────
NEWS_API_KEY=                    # newsapi.org — richer headlines; else Hacker News search is used
COINGECKO_API_KEY=               # Optional CoinGecko demo key for higher rate limits
HUGGINGFACE_API_TOKEN=           # Enables sen_nlp tier (HF inference); else lexicon-only sentiment

# ── x402 (mandatory Stellar settlement) ───────────────────────────────────────
# Every agent call uses HTTP 402 + facilitator settlement.
X402_MAX_TIMEOUT_SECONDS=300   # Payment timeout window (facilitator / requirement metadata)

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
BACKEND_BASE_URL=http://localhost:4000
LOG_LEVEL=info                 # Optional runtime logging level (debug/info/warn/error)