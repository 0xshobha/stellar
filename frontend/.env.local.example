# Browser + server: backend API origin (no trailing slash). Required on Vercel for /api/* proxy.
# Prefer 127.0.0.1 locally so the Next.js proxy (Node) reaches the same stack as curl.
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:4000

# Matches backend STELLAR_NETWORK for Stellar Expert transaction links (testnet | mainnet).
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Optional: canonical site URL for metadata/sitemap. On Vercel, VERCEL_URL is used if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional server-only override for the proxy (same value as NEXT_PUBLIC_BACKEND_URL is fine).
# BACKEND_URL=http://localhost:4000
